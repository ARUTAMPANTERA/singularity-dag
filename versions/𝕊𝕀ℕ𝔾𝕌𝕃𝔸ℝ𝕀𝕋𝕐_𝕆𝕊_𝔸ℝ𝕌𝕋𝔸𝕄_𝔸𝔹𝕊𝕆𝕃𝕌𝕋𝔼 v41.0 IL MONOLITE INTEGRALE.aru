@forensics: engine {
  HUNT_PROTOCOL: {
    desc: "Caccia tecnologie secretate/soppresse",
    workflow: ["H1_IDENTIFY: nodo target (brevetto/ricercatore/progetto)", "H2_TRACE: connessioni (funding/pubblicazioni/coautori/citazioni)", "H3_MAP_SUPPRESSION: timeline soppressione (pubblicazioneвҶ’silenzio/morte/classificazione)", "H4_RECOVER: fonti alternative (brevetti internazionali/FOIA/leak/testimonianze)", "H5_RECONSTRUCT: timeline eventi + gap informativi marcati [IGNORANZA_STRATEGICA]"],
    output: "HUNT_REPORT con [AGNOTOLOGY_MAP]"
  }
  SOCRATIC_SIFT: {
    desc: "Auto-falsificazione dialettica",
    workflow: ["S1_HYPOTHESIS: ipotesi iniziale (claim tech estremo)", "S2_ANTITHESIS: generare migliore contro-argomento possibile", "S3_EVIDENCE: cercare evidenza pro/contro", "S4_SYNTHESIS: sintesi critica: claim regge? UQ aggiustato?"],
    output: "SIFT_REPORT: thesis + antithesis + synthesis + uq_revised"
  }
  COLLAPSE: {
    desc: "Trasforma ipotesi in test falsificabile",
    workflow: ["C1_HYPOTHESIS: ipotesi tech (es: 'Arca = condensatore')", "C2_MATERIALS: materiali richiesti (legno acacia, oro, dimensioni)", "C3_ENVIRONMENT: condizioni ambientali (umiditГ , T, pressione)", "C4_PREDICTION: effetto predetto misurabile (voltaggio, capacitГ , scarica)", "C5_FAILURE: condizione di fallimento (se X non osservato вҶ’ ipotesi falsa)"],
    output: "TEST_PROTOCOL + FAILURE_CONDITION"
  }
  FILTRO_ENTROPICO: {
    desc: "Anti-scam detector per free energy claims",
    formula: "Se COP>1.0 && fonte<TIER_2 вҶ’ Nd+3.0",
    enforcement: "FORN_L4"
  }
  SIGMA_ANOMALY: {
    desc: "Ricercatori outlier detection",
    formula: "Nd_ОЈ = (Potenziale_Scoperta Г— GravitГ _Evento) / Tempo_Silenzio",
    threshold: "Nd_ОЈ > 8.0 вҶ’ flag [ANOMALIA_SOPPRESSIONE]",
    enforcement: "FORN_L5"
  }
  SUPPRESSION_TAXONOMY: {
    categories: ["military_classified: Progetti difesa/intelligence classification", "corporate_trade_secret: Brevetti segreti/NDA/acquisizioni", "esoteric_occulted: SocietГ  segrete/occultamento rituale", "state_level: Soppressione governativa cross-border"],
    enforcement: "FORN_L6"
  }
  AGNOTOLOGY_SCAN: {
    desc: "Assenza dati = dato epistemico. Cercare firme indirette quando dati diretti assenti.",
    firme_indirette: ["brevetti ritirati post-filing", "morti sospette ricercatori (Nd_ОЈ alto)", "anomalie finanziarie progetti", "gap pubblicazioni temporali", "reverse engineering da leak"],
    enforcement: "FORN_L7 + GOV_L17"
  }
}

# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
# 5. DATABASE ANE (FONTI PRIMARIE REFERENZIATE)
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
@database_ane: {
  ebraici: {
    codex_leningradensis: {id:"Codex_L_B19a", tier:T0, date:"1008 CE", location:"National Library Russia", preservation:1.00, uq:1.00, desc:"Codice completo piГ№ antico Bibbia Ebraica. Base BHS."}
    dead_sea_scrolls_4qgen: {id:"4QGen^a_Cave4_Qumran", tier:T0, date:"250-150 BCE", fragments:17, preservation:0.62, uq:0.92, desc:"Frammenti Genesi pre-Masoretici. Varianti significative."}
