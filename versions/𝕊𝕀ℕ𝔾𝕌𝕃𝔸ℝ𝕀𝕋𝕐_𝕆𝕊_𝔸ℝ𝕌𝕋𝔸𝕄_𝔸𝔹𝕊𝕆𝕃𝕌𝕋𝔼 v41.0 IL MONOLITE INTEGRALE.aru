    RWH:{cons:"ЧЁ-Ч•-Ч—", ipa:"/ЛҲruЛҗaД§/", pela13:"rwбёҘ", akk:"rЕ«qu [CAD R] вҖ” vuoto/distante (etimologia incerta)", ug:"rбёҘ [KTU 1.1] вҖ” vento/forza propulsiva", glossa:"vento/soffio вҶ’ flusso/pressione вҶ’ pneuma (espansione ellenistica)", spectrum:{fisico:"flusso/vettore propulsivo/pressione", astratto:"volontГ /direzione/intenzione", teologico:"spirito/soffio vitale"}, freq:{abs:378, norm:0.0091, sig:0.0213}, confidence:0.96}
